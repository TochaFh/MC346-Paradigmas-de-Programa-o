   "source": [
    "; exemplo de grafo direcionado com lista de adjacência\n",
    "(define grafo-teste\n",
    "  '(\n",
    "    (A . (B C E))\n",
    "    (B . (C))\n",
    "    (C . (B E))\n",
    "    (E . ())\n",
    "  )\n",
    ")\n",
    "\n",
    "(define (filhos p grafo)\n",
    "  (cdr (assq p grafo))\n",
    ")\n",
    "\n",
    "(display (filhos 'C grafo-teste))\n",
    "(newline)\n",
    "\n",
    "(display grafo-teste)"
   ]
